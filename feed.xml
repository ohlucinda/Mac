---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:webfeeds="http://webfeeds.org/rss/1.0">

  <channel>

    <title>OHLUCINDA</title>

    <link>https://ohlucinda.com/</link>

    <description>
      Words, music, images, and experiments by OHLUCINDA
    </description>

    <image>
      <url>https://ohlucinda.com/images/apple-touch-icon.png</url>

      <title>OHLUCINDA</title>

      <link>https://ohlucinda.com/</link>
    </image>

    <webfeeds:icon>
      https://ohlucinda.com/images/apple-touch-icon.png
    </webfeeds:icon>

    <webfeeds:accentColor>
      #000000
    </webfeeds:accentColor>

    {% for post in site.posts %}

    <item>

      <title>{{ post.title }}</title>

      <link>
        https://ohlucinda.com{{ post.url }}
      </link>


  <item>

  <title>{{ post.title }}</title>

  <link>...</link>

   <media:content
   url="https://ohlucinda.com/images/{{ post.image }}"
   medium="image" />

  <description>
<![CDATA[
{% if post.image %}
<img src="https://ohlucinda.com/images/{{ post.image }}" />
{% endif %}

{{ post.excerpt | strip_html | strip_newlines }}
]]>
</description>

 </item>

    {% endfor %}

  </channel>

</rss>
